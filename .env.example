# Copy to .env and fill in. .env is gitignored.
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Production auth: when set, every mutating endpoint requires
#   Authorization: Bearer <token>   (the web app prompts once and stores it)
# Leave empty for open local dev.
SHOWRUNNER_TOKEN=

# OpenAI-compatible endpoint for Qwen text + vision-language models
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# DashScope native endpoint for async video generation
VIDEO_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# Model IDs — smoke_test.py verifies these; adjust if the API rejects an id.
QWEN_PLANNER_MODEL=qwen3.7-max
QWEN_FAST_MODEL=qwen3.7-plus
QWEN_VL_MODEL=qwen3.6-plus

# Video model. Wan is confirmed via docs; HappyHorse is the flagship — try both.
#   Candidates: wan2.7-t2v, wan2.7-i2v, happyhorse-1.1-t2v, happyhorse-1.1-i2v
VIDEO_T2V_MODEL=wan2.7-t2v
VIDEO_I2V_MODEL=wan2.7-i2v
